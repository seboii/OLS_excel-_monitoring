# ============================================================================
#  OLS Operasyon Kontrol Merkezi — Ortam Değişkenleri (ŞABLON)
#  Bu dosyayı `.env` olarak kopyalayın ve kendi değerlerinizi girin.
#  `.env` ASLA commit'lenmez (.gitignore'da).
# ============================================================================

# ───────────── PostgreSQL (KENDİ ŞİFRENİZİ SİZ BELİRLEYİN) ─────────────
POSTGRES_USER=ols
POSTGRES_PASSWORD=DEGISTIR_guclu_bir_sifre_girin
POSTGRES_DB=ols_control_center

# ───────────── Redis ─────────────
# (Şimdilik şifresiz; gerekirse REDIS_PASSWORD ekleyin)

# ───────────── JWT (Auth modülü) ─────────────
JWT__Secret=DEGISTIR_en_az_32_karakterlik_uzun_rastgele_bir_anahtar
JWT__Issuer=ols-control-center
JWT__Audience=ols-control-center
JWT__AccessTokenMinutes=60
JWT__RefreshTokenDays=7

# ───────────── Bağlantı bilgisi şifreleme (data source token'ları) ─────────────
ENCRYPTION__Key=DEGISTIR_base64_32_byte_anahtar

# ───────────── Seed admin (ilk kurulum) ─────────────
SEED__AdminEmail=admin@ols.local
SEED__AdminPassword=DEGISTIR_Admin123!

# ───────────── AI Yönetim Özeti (Claude) ─────────────
# Anahtar boşsa AI özeti devre dışı kalır; dashboard kural-tabanlı özete düşer.
# Anahtarı https://console.anthropic.com adresinden alın.
AI__ApiKey=
AI__Model=claude-opus-4-8
AI__Enabled=true

# ───────────── VERİ KAYNAĞI LİNKLERİ (KENDİ LİNKLERİNİZİ GİRİN) ─────────────
# Senkron motoru (connector) bu linklerden veri çeker. Boş bırakılabilir;
# arayüzdeki "Veri Kaynakları" ekranından da eklenebilir.
DATASOURCE__ROAD_LTL_URL=
DATASOURCE__ROAD_FTL_URL=
DATASOURCE__SEA_URL=
DATASOURCE__AIR_URL=
DATASOURCE__FINANCE_URL=
DATASOURCE__SHAREPOINT_URL=
DATASOURCE__YANDEX_PUBLIC_URL=
DATASOURCE__GOOGLE_SHEET_ID=

# ───────────── Host portları ─────────────
API_PORT=5080
WEB_PORT=8088
